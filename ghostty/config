# Generated by Spectre - Ghostty Config Generator
# https://github.com/imrajyavardhan12/spectre-ghostty-config

# Shell
env = SIMPLE_CLAUDE_DISABLE_NOTIFICATIONS=1
shell-integration = detect
shell-integration-features = sudo,ssh-terminfo,ssh-env
 # Use nightly build
auto-update-channel = tip

# Fonts
font-family = "ZenbonesBrainy Nerd Font"
font-size = 13

# Macos
macos-titlebar-style = hidden
auto-update = download

# Keybinds - general
keybind = shift+enter=text:‰
keybind = global:cmd+grave_accent=toggle_quick_terminal
keybind = "super+shift+comma=text:theme light\n"
keybind = "super+shift+period=text:theme dark\n"
# keybind = "super+slash=text:theme next\n"  # cycling not yet supported by the-themer
keybind = super+shift+r=reload_config

# Keybinds - tmux
# All pane/window/tab management delegated to tmux.
# Ghostty sends prefix (\x01 = C-a) followed by the tmux key.
keybind = cmd+a=text:\x01
keybind = cmd+d=text:\x01%
keybind = cmd+shift+d=text:\x01"
keybind = cmd+t=text:\x01c
keybind = cmd+w=text:\x01x
keybind = cmd+left=text:\x01\x08
keybind = cmd+right=text:\x01\x0c
keybind = cmd+shift+w=text:\x01&
keybind = "cmd+[=text:⁋"
keybind = "cmd+]=text:⁂"
keybind = cmd+e=text:\x01\x14

# Clipboard
copy-on-select = clipboard
clipboard-paste-protection = false
clipboard-read = allow
clipboard-write = allow

# Window
window-save-state = always
window-inherit-working-directory = true
window-subtitle = working-directory
unfocused-split-fill = #b2bec3
# unfocused-split-opacity = 0.85
unfocused-split-opacity = 1
split-divider-color = #5f27cd

# Colors
# Theme loaded from theme.local (written by switch-theme.sh, gitignored)
config-file = ?theme.local
