      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "tail-claude-hud hook heartbeat"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/kyle/Code/meta-claude/opensessions/scripts/hook.sh PostToolUse",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/kyle/Code/dotfiles/claude/hooks/log-skill.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/kyle/Library/Application Support/tokf/hooks/pre-tool-use.sh'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "tail-claude-hud hook heartbeat"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/kyle/Code/meta-claude/opensessions/scripts/hook.sh PreToolUse",
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/kyle/Code/meta-claude/opensessions/scripts/hook.sh SessionEnd",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/kyle/Code/meta-claude/opensessions/scripts/hook.sh SessionStart",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tail-claude-hud hook cleanup"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "tail-claude-hud hook stop-cleanup"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/kyle/Code/meta-claude/opensessions/scripts/hook.sh Stop",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/kyle/Code/meta-claude/opensessions/scripts/hook.sh UserPromptSubmit",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "tail-claude-hud"
  },
