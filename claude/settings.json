{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "400000",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "ENABLE_LSP_TOOL": "1",
    "MAX_MCP_OUTPUT_TOKENS": "50000",
    "MCP_TIMEOUT": "120000",
    "MCP_TOOL_TIMEOUT": "120000",
    "RUBY_CLAUDE_HOOKS_DEBUG_MODE": "true"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Agent",
      "WebFetch",
      "WebSearch",
      "Bash(./the-themer:*)",
      "Bash(bash -n:*)",
      "Bash(bd:*)",
      "Bash(bl:*)",
      "Bash(bundle exec rspec:*)",
      "Bash(bundle exec rubocop:*)",
      "Bash(gem list:*)",
      "Bash(rubocop:*)",
      "Bash(shellcheck:*)",
      "Bash(go build:*)",
      "Bash(go mod tidy:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(check-jsonschema:*)",
      "Bash(eza:*)",
      "Bash(printenv:*)",
      "Bash(textutil:*)",
      "Bash(whereis:*)",
      "Bash(git -C:*)",
      "Bash(git checkout:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git worktree add:*)",
      "Bash(gh api:*)",
      "Bash(gh pr create:*)",
      "Bash(gh repo clone:*)",
      "Bash(jira issue list:*)",
      "Bash(jira issue view:*)",
      "Bash(just build)",
      "Bash(just check)",
      "Bash(just test)",
      "Bash(ln:*)",
      "Bash(mcp-cli call:*)",
      "Bash(mkdir:*)",
      "mcp__just__build",
      "mcp__just__check",
      "mcp__just__test",
      "mcp__plugin_envato-mcp-servers_atlassian",
      "mcp__plugin_envato-mcp-servers_buildkite",
      "mcp__plugin_envato-mcp-servers_context7",
      "mcp__plugin_envato-mcp-servers_rollbar"
    ],
    "deny": [
      "Bash(aws-vault:*)",
      "Bash(git push --force)"
    ],
    "ask": [
      "Bash(curl:*)",
      "Bash(gh api --field:*)",
      "Bash(gh api --input:*)",
      "Bash(gh api --method DELETE:*)",
      "Bash(gh api --method PATCH:*)",
      "Bash(gh api --method POST:*)",
      "Bash(gh api --method PUT:*)",
      "Bash(gh api --raw-field:*)",
      "Bash(gh api -F:*)",
      "Bash(gh api -X DELETE:*)",
      "Bash(gh api -X PATCH:*)",
      "Bash(gh api -X POST:*)",
      "Bash(gh api -X PUT:*)",
      "Bash(gh api -f:*)",
      "Bash(gh api graphql:*)",
      "Bash(gh pr checkout:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr lock:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr ready:*)",
      "Bash(gh pr reopen:*)",
      "Bash(gh pr revert:*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr unlock:*)",
      "Bash(gh pr update-branch:*)",
      "Bash(git -C push:*)",
      "Bash(git push:*)",
      "Bash(rm:*)",
      "Bash(rm -rf:*)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "/tmp",
      "/Users/kyle/Code/dotfiles",
      "/Users/kyle/.config/nvim"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/kyle/Code/meta-claude/opensessions/scripts/hook.sh Notification",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/kyle/Code/meta-claude/claude-remote-approver/bin/cli.mjs\" hook"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "tail-claude-hud hook permission-request"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/kyle/Code/meta-claude/opensessions/scripts/hook.sh PermissionRequest",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
